# Normalize line endings across the repo
* text=auto

# Force LF for source and config files
*.py   text eol=lf
*.pyi  text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.txt  text eol=lf

# Keep Windows scripts with CRLF
*.ps1  text eol=crlf
*.bat  text eol=crlf

# Images/binaries (do not modify line endings)
*.png  -text
*.jpg  -text
*.jpeg -text
*.gif  -text
*.svg  -text
*.pdf  -text
*.npy  -text
*.pt   -text
*.pth  -text
